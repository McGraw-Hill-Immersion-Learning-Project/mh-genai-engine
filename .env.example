# ── App
APP_ENV=development

# ── LLM Provider
LLM_PROVIDER=gemini          # gemini | anthropic
LLM_MODEL=gemini-3-flash-preview   # model name supported by the chosen provider

# ── Embedding Provider
EMBEDDING_PROVIDER=gemini    # gemini
EMBEDDING_MODEL=text-embedding-004

# ── Vector DB
VECTOR_DB_PROVIDER=chroma    # chroma | pgvector
# CHROMA_HOST=               # leave empty for embedded mode
# CHROMA_PORT=8000
# DATABASE_URL=              # required if VECTOR_DB_PROVIDER=pgvector

# ── Document Storage
STORAGE_PROVIDER=local       # local | s3
STORAGE_LOCAL_PATH=data/raw  # base path for local storage
# S3_BUCKET=                 # required if STORAGE_PROVIDER=s3
# S3_REGION=us-east-1

# ── API Keys (never commit real values)
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
