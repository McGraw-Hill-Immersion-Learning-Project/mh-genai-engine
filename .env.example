# ── App
APP_ENV=development
# LOG_LEVEL=INFO            # DEBUG = verbose app.* logs (e.g. full RAG prompts)
# REQUEST_TIMEOUT_SECONDS=120   # per-request limit (seconds); 0 = no limit

# ── LLM Provider
LLM_PROVIDER=anthropic       # anthropic | gemini
LLM_MODEL=claude-sonnet-4-6  # model name supported by the chosen provider

# ── Embedding Provider
EMBEDDING_PROVIDER=voyage    # voyage | gemini | dev (synthetic local)
EMBEDDING_MODEL=voyage-4-lite
# For local dev embeddings without any external API calls:
# EMBEDDING_PROVIDER=dev
# EMBEDDING_MODEL=local-dev

# ── Vector DB (pgvector)
VECTOR_DB_PROVIDER=pgvector
DATABASE_URL=postgresql://mhgenai:mhgenai@localhost:5432/mhgenai

# ── Document Storage
STORAGE_PROVIDER=local       # local | s3
STORAGE_LOCAL_PATH=data/raw  # base path for local storage
# S3_BUCKET=                 # required if STORAGE_PROVIDER=s3
# S3_REGION=us-east-1

# ── Ingestion
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_DIMENSIONS=1024    # voyage-4-lite default (dev overrides to DEV_EMBEDDING_DIMENSIONS)
EMBEDDING_BATCH_SIZE=64
# Voyage free tier (3 RPM): set EMBEDDING_BATCH_SIZE=3 and EMBEDDING_BATCH_DELAY_SECONDS=21
EMBEDDING_BATCH_DELAY_SECONDS=0

# ── Dev embedding fast defaults (used when EMBEDDING_PROVIDER=dev)
DEV_EMBEDDING_DIMENSIONS=128
DEV_EMBEDDING_BATCH_SIZE=512
DEV_MAX_CHUNKS=0             # 0 = no cap; set e.g. 200 to make dev runs very fast

# ── API Keys (never commit real values)
# ANTHROPIC_API_KEY=          # required when LLM_PROVIDER=anthropic (install: anthropic>=0.80 in requirements.txt)
# VOYAGE_API_KEY=
# GEMINI_API_KEY=
