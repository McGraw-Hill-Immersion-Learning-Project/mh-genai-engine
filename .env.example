# ── App
APP_ENV=development

# ── LLM Provider
LLM_PROVIDER=anthropic       # anthropic | gemini
LLM_MODEL=claude-sonnet-4-6  # model name supported by the chosen provider

# ── Embedding Provider
EMBEDDING_PROVIDER=voyage    # voyage | gemini
EMBEDDING_MODEL=voyage-4-lite

# ── Vector DB (pgvector)
VECTOR_DB_PROVIDER=pgvector
DATABASE_URL=postgresql://mhgenai:mhgenai@localhost:5432/mhgenai

# ── Document Storage
STORAGE_PROVIDER=local       # local | s3
STORAGE_LOCAL_PATH=data/raw  # base path for local storage
# S3_BUCKET=                 # required if STORAGE_PROVIDER=s3
# S3_REGION=us-east-1

# ── Ingestion
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=64

# ── API Keys (never commit real values)
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# GEMINI_API_KEY=
