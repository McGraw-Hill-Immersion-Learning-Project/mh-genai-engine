# ── App
APP_ENV=development

# ── LLM Provider
LLM_PROVIDER=anthropic       # anthropic | gemini
LLM_MODEL=claude-sonnet-4-6  # model name supported by the chosen provider

# ── Embedding Provider
EMBEDDING_PROVIDER=voyage    # voyage | gemini
EMBEDDING_MODEL=voyage-3-large

# ── Vector DB
VECTOR_DB_PROVIDER=chroma    # chroma | pgvector
# CHROMA_HOST=               # leave empty for embedded mode
# CHROMA_PORT=8000
# DATABASE_URL=              # required if VECTOR_DB_PROVIDER=pgvector

# ── Document Storage
STORAGE_PROVIDER=local       # local | s3
STORAGE_LOCAL_PATH=data/raw  # base path for local storage
# S3_BUCKET=                 # required if STORAGE_PROVIDER=s3
# S3_REGION=us-east-1

# ── API Keys (never commit real values)
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# GEMINI_API_KEY=
